# PostgreSQL 연결 방법 1: 연결 문자열 (DATABASE_URL이 있으면 우선 사용)
# 형식: postgresql://유저명:비밀번호@호스트:포트/DB명
DATABASE_URL=postgresql://postgres:password@localhost:5432/db_designer

# PostgreSQL 연결 방법 2: 개별 설정 (DATABASE_URL이 없을 때 사용)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=db_designer
DB_SCHEMA=public

# AI API 키 (Anthropic 또는 OpenAI 중 하나 이상 필요)
# 앱 UI의 설정(⚙️)에서 입력해도 됩니다
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
